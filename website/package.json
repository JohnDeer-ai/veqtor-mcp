{
  "name": "@veqtor/website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build && node scripts/check-site.mjs && node scripts/check-copy.mjs",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "test": "node --test scripts/*.test.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/roboto-mono": "5.2.9",
    "astro": "7.0.9"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "parse5": "7.3.0",
    "typescript": "6.0.3"
  }
}
