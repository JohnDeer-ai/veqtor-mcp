---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="404 — Page Not Found | Veqtor"
  description="The requested page could not be found on the Veqtor website."
  canonicalPath="/404"
  noindex
>
  <section class="not-found shell">
    <span>ERROR / 404</span>
    <h1>This page isn’t here.</h1>
    <p>The address may be outdated or mistyped. The contract guide library and product documentation are still available.</p>
    <div class="actions"><a class="button button--primary" href="/">Go to the homepage</a><a class="button button--secondary" href="/guides">Browse the guides</a><a class="button button--quiet" href="/docs">Open the docs</a></div>
  </section>
</BaseLayout>

<style>
  .not-found { min-height: 68vh; padding-bottom: 100px; padding-top: 100px; }
  .not-found > span { color: var(--lime); font-family: var(--mono); font-size: 11px; font-weight: var(--weight-label); letter-spacing: .08em; }
  .not-found h1 { margin-top: 34px; max-width: 760px; }
  .not-found p { color: var(--muted); font-size: 18px; max-width: 620px; }
  .not-found .actions { margin-top: 32px; }
</style>
