---
import BaseLayout from '../../layouts/BaseLayout.astro'
import GuideCard from '../../components/GuideCard.astro'
import {
  AUTHOR,
  GUIDES,
  formatGuideDate,
  guideAnchorId,
  guideStructuredData,
  productBridgeForGuide,
  relatedGuides,
  renderInline,
  topicForGuide,
  type Guide,
} from '../../lib/guides'

export function getStaticPaths() {
  return GUIDES.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }))
}

const { guide } = Astro.props as { guide: Guide }
const topic = topicForGuide(guide)
const productBridge = productBridgeForGuide(guide)
const related = relatedGuides(guide)
const topicIndex = topic.guides.findIndex((entry) => entry.slug === guide.slug)
const previousGuide = topicIndex > 0 ? topic.guides[topicIndex - 1] : undefined
const nextGuide = topicIndex >= 0 && topicIndex < topic.guides.length - 1
  ? topic.guides[topicIndex + 1]
  : undefined
---

<BaseLayout
  title={guide.metaTitle}
  twitterTitle={guide.twitterTitle}
  description={guide.metaDescription}
  canonicalPath={guide.path}
  type="article"
  publishedTime={guide.publishedAt}
  modifiedTime={guide.modifiedAt}
  structuredData={guideStructuredData(guide)}
>
  <div class="article-page">
    <div class="shell crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span><a href="/guides">Guides</a><span>/</span>
      <a href={topic.path}>{topic.label}</a><span>/</span><b>{guide.breadcrumb}</b>
    </div>

    <header class="article-hero shell">
      <div>
        <p class="kicker">{topic.stage.label} / {topic.label}</p>
        <h1>{guide.h1}</h1>
        <p class="lede" set:html={renderInline(guide.lede)} />
        <div class="byline">
          <a href={AUTHOR.path}>Ilya Shilov, LL.M.</a>
          <span>Updated {formatGuideDate(guide.modifiedAt)}</span>
          <span>{guide.readingTime} min read</span>
        </div>
      </div>
      <aside class="topic-context">
        <span>{guide.kind === 'pillar' ? 'Pillar guide' : guide.listing.label}</span>
        <strong>{topic.label}</strong>
        <p>{guide.kind === 'pillar'
          ? `${topic.spokes.length} focused articles build on this guide.`
          : `Part of a connected library of ${topic.guides.length} guides.`}</p>
        <a href={topic.path}>Open topic map →</a>
      </aside>
    </header>

    <section class="article-shell shell">
      <aside class="toc">
        <nav aria-label="On this guide">
          <p class="kicker">On this guide</p>
          {guide.sections.map((section, index) => (
            <a href={`#${guideAnchorId(section.title)}`}>
              <span>{String(index + 1).padStart(2, '0')}</span>{section.title}
            </a>
          ))}
          <a href="#practical-checklist"><span>{String(guide.sections.length + 1).padStart(2, '0')}</span>Practical checklist</a>
          {guide.sources.length > 0 && (
            <a href="#sources-heading"><span>{String(guide.sections.length + 2).padStart(2, '0')}</span>Sources</a>
          )}
        </nav>
      </aside>

      <article class="article-body">
        {guide.sections.map((section) => (
          <section aria-labelledby={guideAnchorId(section.title)}>
            <h2 id={guideAnchorId(section.title)}>{section.title}</h2>
            {section.body.map((block) => {
              if (typeof block === 'string') return <p set:html={renderInline(block)} />
              if (block.type === 'list') {
                const items = block.items.map((item) => <li set:html={renderInline(item)} />)
                return block.ordered ? <ol class="body-list">{items}</ol> : <ul class="body-list">{items}</ul>
              }
              if (block.type === 'quote') {
                return (
                  <blockquote class="body-quote">
                    {block.body.map((entry) => <p set:html={renderInline(entry)} />)}
                  </blockquote>
                )
              }
              return (
                <div class="table-wrap" tabindex="0" role="region" aria-label={`Table: ${section.title}`}>
                  <table>
                    <thead>
                      <tr>{block.header.map((cell) => <th scope="col" set:html={renderInline(cell)} />)}</tr>
                    </thead>
                    <tbody>
                      {block.rows.map((row) => (
                        <tr>
                          {row.map((cell, cellIndex) => cellIndex === 0
                            ? <th scope="row" set:html={renderInline(cell)} />
                            : <td set:html={renderInline(cell)} />)}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )
            })}
          </section>
        ))}

        <section class="checklist" aria-labelledby="practical-checklist">
          <p class="kicker">Use at the desk</p>
          <h2 id="practical-checklist">Practical checklist</h2>
          <ul>
            {guide.checklist.map((item) => <li set:html={renderInline(item)} />)}
          </ul>
        </section>

        {guide.sources.length > 0 && (
          <section class="sources" aria-labelledby="sources-heading">
            <p class="kicker">Primary material</p>
            <h2 id="sources-heading">Sources</h2>
            <ul>
              {guide.sources.map((item) => <li set:html={renderInline(item)} />)}
            </ul>
          </section>
        )}

        <p class="disclaimer">
          This guide is informational only and is not legal advice. It does not replace advice
          from licensed counsel on the facts of a specific transaction.
        </p>

        <section class="product-bridge" aria-labelledby="product-bridge-heading">
          <p class="kicker">{productBridge.label}</p>
          <h2 id="product-bridge-heading">{productBridge.heading}</h2>
          <p>{productBridge.body}</p>
          <a class="button button--primary" href={productBridge.href}>{productBridge.title}</a>
        </section>

        {related.length > 0 && (
          <section class="related" aria-labelledby="related-heading">
            <div class="related__heading">
              <p class="kicker">Continue reading</p>
              <h2 id="related-heading">Related guides.</h2>
            </div>
            <div class="related__grid">
              {related.slice(0, 6).map((entry) => (
                <GuideCard guide={entry} topicLabel={topicForGuide(entry).label} compact />
              ))}
            </div>
          </section>
        )}

        {(previousGuide || nextGuide) && (
          <nav class="prev-next" aria-label="Guide sequence">
            {previousGuide
              ? <a href={previousGuide.path}><span>← Previous in topic</span><strong>{previousGuide.listing.title}</strong></a>
              : <span></span>}
            {nextGuide
              ? <a href={nextGuide.path}><span>Next in topic →</span><strong>{nextGuide.listing.title}</strong></a>
              : <span></span>}
          </nav>
        )}
      </article>

      <aside class="topic-rail">
        <p class="kicker">More in this topic</p>
        {topic.guides.filter((entry) => entry.slug !== guide.slug).slice(0, 8).map((entry) => (
          <a href={entry.path}>
            <span>{entry.kind === 'pillar' ? 'Pillar' : entry.listing.label}</span>
            <strong>{entry.listing.title}</strong>
          </a>
        ))}
      </aside>
    </section>
  </div>
</BaseLayout>

<style>
  .article-page {
    --ink: #eeedf5;
    --muted: #aaa6b7;
    --panel: #111019;
    --panel-raised: #17151f;
    --line: #302d3c;
    --accent: #8f80ff;
    --accent-soft: #c0b9ff;
    color: var(--ink);
  }

  .shell {
    width: min(1220px, calc(100% - 2.5rem));
    margin-inline: auto;
  }

  /* Only the article grid runs wide (the global .shell caps width at
     var(--shell) = 1240px, hence the lifted max-width). Breadcrumbs and the
     hero stay in the narrow shell, aligned with the global header. */
  .article-shell.shell {
    width: min(1800px, calc(100% - 2.5rem));
    max-width: none;
  }

  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 1.4rem;
    color: var(--muted);
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.72rem;
  }

  .crumbs a {
    color: inherit;
    text-decoration: none;
  }

  .crumbs b {
    color: var(--ink);
  }

  .article-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(16rem, 0.42fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: end;
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .kicker,
  .topic-context > span {
    margin: 0 0 1rem;
    color: var(--accent-soft);
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.72rem;
    font-weight: var(--weight-label);
    letter-spacing: 0.09em;
    line-height: 1.45;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 18ch;
    margin-bottom: 1.6rem;
    font-size: var(--type-article-title);
    letter-spacing: var(--tracking-display);
    line-height: 1.05;
    text-wrap: balance;
  }

  .lede {
    max-width: 70ch;
    margin-bottom: 1.5rem;
    color: var(--muted);
    font-size: clamp(1.06rem, 2vw, 1.3rem);
    line-height: 1.67;
  }

  .byline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1.3rem;
    color: var(--muted);
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .byline a {
    color: var(--accent-soft);
    text-decoration: none;
  }

  .topic-context {
    padding: 1.35rem;
    background: linear-gradient(145deg, rgb(143 128 255 / 11%), transparent 55%), var(--panel);
    border: 1px solid var(--line);
    border-radius: 0.9rem;
  }

  .topic-context strong {
    display: block;
    margin-bottom: 0.65rem;
    font-size: 1.25rem;
    font-weight: var(--weight-title);
  }

  .topic-context p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .topic-context a {
    color: var(--accent-soft);
    font-size: 0.8rem;
    font-weight: var(--weight-control);
    text-decoration: none;
  }

  /* Fixed rails, flexible article column: on a wide screen the article gets
     the space, while plain paragraphs below keep a readable measure. */
  .article-shell {
    display: grid;
    grid-template-columns: 15rem minmax(0, 1fr) 19rem;
    gap: clamp(1.5rem, 4.5vw, 4.5rem);
    align-items: start;
    padding-bottom: clamp(5rem, 10vw, 9rem);
  }

  .toc,
  .topic-rail {
    position: sticky;
    top: 6rem;
  }

  .toc nav,
  .topic-rail {
    display: flex;
    flex-direction: column;
  }

  .toc a {
    display: grid;
    grid-template-columns: 1.6rem 1fr;
    gap: 0.4rem;
    padding-block: 0.55rem;
    color: var(--muted);
    font-size: 0.74rem;
    line-height: 1.35;
    text-decoration: none;
    border-bottom: 1px solid var(--line);
  }

  .toc a span,
  .topic-rail a span {
    color: var(--accent-soft);
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* Grid items default to min-width auto, which lets a wide table stretch the
     page instead of scrolling inside its own container. */
  .article-body {
    min-width: 0;
  }

  .article-body > section:not(.product-bridge, .related, .checklist) {
    padding-bottom: 2.1rem;
    margin-bottom: 2.1rem;
    border-bottom: 1px solid var(--line);
  }

  .article-body h2 {
    max-width: 23ch;
    margin-bottom: 1.2rem;
    font-size: clamp(1.7rem, 3vw, 2.55rem);
    letter-spacing: var(--tracking-heading);
    line-height: 1.12;
    scroll-margin-top: 6rem;
  }

  .article-body > section > p:not(.kicker),
  .product-bridge > p:not(.kicker) {
    color: #c9c6d2;
    font-size: clamp(1rem, 1.4vw, 1.08rem);
    line-height: 1.82;
  }

  /* Prose keeps a readable measure; tables, checklists, quotes and other
     large blocks use the full article column. */
  .article-body > section > p:not(.kicker) {
    max-width: 74ch;
  }

  .article-body > section > p:last-child {
    margin-bottom: 0;
  }

  .checklist {
    margin-block: 2.5rem;
    padding: clamp(1.4rem, 4vw, 2.3rem);
    background: var(--panel-raised);
    border: 1px solid var(--line);
    border-radius: 0.9rem;
  }

  .checklist ul {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .checklist li {
    position: relative;
    padding-left: 1.55rem;
    color: #d2cfda;
    line-height: 1.6;
  }

  .checklist li::before {
    position: absolute;
    top: 0.58em;
    left: 0;
    width: 0.52rem;
    height: 0.52rem;
    content: '';
    background: var(--accent);
    border-radius: 0.15rem;
  }

  .disclaimer {
    margin-block: 2rem;
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.6;
  }

  .lede :global(a),
  .article-body :global(:is(p, li, td) a:not(.button)) {
    color: var(--accent-soft);
    text-decoration: underline;
    text-decoration-color: rgb(192 185 255 / 45%);
    text-underline-offset: 0.16em;
  }

  .article-body :global(.body-list) {
    display: grid;
    gap: 0.55rem;
    margin: 0 0 1.5rem;
    padding-left: 1.25rem;
    max-width: 74ch;
    color: #c9c6d2;
    font-size: clamp(1rem, 1.4vw, 1.08rem);
    line-height: 1.72;
  }

  .article-body :global(.body-list li::marker) {
    color: var(--accent-soft);
  }

  .article-body :global(.body-quote) {
    margin: 0 0 1.5rem;
    padding: clamp(1.1rem, 3vw, 1.7rem);
    background: var(--panel);
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent);
    border-radius: 0 0.7rem 0.7rem 0;
  }

  .article-body :global(.body-quote p) {
    margin-bottom: 1rem;
    color: #d2cfda;
    font-size: 0.98rem;
    line-height: 1.75;
  }

  .article-body :global(.body-quote p:last-child) {
    margin-bottom: 0;
  }

  .article-body :global(.table-wrap) {
    margin: 0 0 1.5rem;
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 0.7rem;
  }

  .article-body :global(.table-wrap table) {
    width: 100%;
    min-width: 44rem;
    border-collapse: collapse;
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .article-body :global(.table-wrap th) {
    padding: 0.75rem 0.9rem;
    color: var(--accent-soft);
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.68rem;
    font-weight: var(--weight-label);
    letter-spacing: 0.08em;
    text-align: left;
    text-transform: uppercase;
    background: var(--panel-raised);
    border-bottom: 1px solid var(--line);
  }

  .article-body :global(.table-wrap td),
  .article-body :global(.table-wrap tbody th) {
    padding: 0.8rem 0.9rem;
    color: #c9c6d2;
    vertical-align: top;
    border-bottom: 1px solid var(--line);
  }

  .article-body :global(.table-wrap tbody th) {
    font-weight: var(--weight-title);
    text-align: left;
  }

  .article-body :global(.table-wrap tbody tr:last-child td),
  .article-body :global(.table-wrap tbody tr:last-child th) {
    border-bottom: 0;
  }

  .article-body :global(.table-wrap:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .sources :global(ul) {
    display: grid;
    gap: 0.6rem;
    margin: 0;
    padding-left: 1.25rem;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .sources :global(li::marker) {
    color: var(--accent-soft);
  }

  .product-bridge {
    margin-block: 3rem;
    padding: clamp(1.4rem, 4vw, 2.4rem);
    background: linear-gradient(130deg, rgb(143 128 255 / 17%), transparent 60%), var(--panel);
    border: 1px solid var(--line);
    border-radius: 0.9rem;
  }

  .product-bridge h2 {
    max-width: 19ch;
  }

  .button {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 1.05rem;
    color: var(--ink);
    font-size: 0.82rem;
    font-weight: var(--weight-control);
    text-decoration: none;
    border: 1px solid var(--line);
    border-radius: 0.55rem;
  }

  .button--primary {
    color: #0b0912;
    background: var(--accent-soft);
    border-color: var(--accent-soft);
  }

  .related {
    margin-block: 4rem;
  }

  .related__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .topic-rail {
    gap: 0;
  }

  .topic-rail a {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-block: 0.75rem;
    color: var(--ink);
    font-size: 0.78rem;
    line-height: 1.35;
    text-decoration: none;
    border-bottom: 1px solid var(--line);
  }

  .topic-rail strong,
  .prev-next strong {
    font-weight: var(--weight-title);
  }

  .prev-next {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 3rem;
  }

  .prev-next a {
    display: flex;
    min-height: 7rem;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 1rem;
    color: var(--ink);
    text-decoration: none;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 0.7rem;
  }

  .prev-next a span {
    color: var(--accent-soft);
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  /* Thresholds sit where the extra rail would squeeze the article below the
     704px table: the rail returns only once the centre column stays wide. */
  @media (max-width: 1680px) {
    .article-shell {
      grid-template-columns: 15rem minmax(0, 1fr);
    }

    .topic-rail {
      display: none;
    }
  }

  @media (max-width: 1140px) {
    .article-hero,
    .article-shell {
      grid-template-columns: 1fr;
    }

    .topic-rail {
      display: none;
    }

    .topic-context {
      max-width: 28rem;
    }

    .toc {
      position: static;
      padding: 1rem;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 0.8rem;
    }
  }

  @media (max-width: 540px) {
    /* The wide article rule is more specific than .shell, so it needs its own
       mobile override or narrow screens would keep the 2.5rem margin. */
    .shell,
    .article-shell.shell {
      width: min(100% - 1.25rem, 1220px);
    }

    .related__grid,
    .prev-next {
      grid-template-columns: 1fr;
    }
  }
</style>
