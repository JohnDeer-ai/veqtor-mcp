---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import SiteCta from '../components/SiteCta.astro'
import { DEMO_VIDEO } from '../lib/demo-video'

const title = 'Veqtor MCP Demo — Review Word Redlines with Claude'
const description = DEMO_VIDEO.description
const pageSchema = {
  '@type': 'WebPage',
  '@id': `${DEMO_VIDEO.pageUrl}#webpage`,
  url: DEMO_VIDEO.pageUrl,
  name: title,
  description,
  isPartOf: { '@id': 'https://veqtor.pro/#website' },
  mainEntity: { '@id': DEMO_VIDEO.id },
  inLanguage: 'en',
}
const videoSchema = {
  '@type': 'VideoObject',
  '@id': DEMO_VIDEO.id,
  name: DEMO_VIDEO.name,
  description,
  thumbnailUrl: DEMO_VIDEO.thumbnailUrl,
  contentUrl: DEMO_VIDEO.contentUrl,
  uploadDate: DEMO_VIDEO.uploadDate,
  duration: DEMO_VIDEO.duration,
  url: DEMO_VIDEO.pageUrl,
  mainEntityOfPage: { '@id': pageSchema['@id'] },
}
const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://veqtor.pro/' },
    { '@type': 'ListItem', position: 2, name: 'Demo', item: DEMO_VIDEO.pageUrl },
  ],
}
---

<BaseLayout title={title} description={description} canonicalPath="/demo" structuredData={[pageSchema, videoSchema, breadcrumbSchema]}>
  <section class="page-hero page-hero--compact demo-hero">
    <div class="shell">
      <Breadcrumbs items={[{ label: 'Demo' }]} />
      <div class="demo-hero__grid">
        <div class="demo-hero__title">
          <p class="eyebrow">Sample contract workflow</p>
          <h1 id="demo-title">See Claude move from four Word drafts to a reviewable counterproposal.</h1>
        </div>
        <div class="demo-hero__media" id="watch">
          <div class="demo-video">
            <video controls playsinline preload="metadata" poster={DEMO_VIDEO.thumbnailPath} aria-labelledby="demo-title">
              <source src={DEMO_VIDEO.contentPath} type="video/mp4" />
              <track kind="captions" src={DEMO_VIDEO.captionsPath} srclang="en" label="English" default />
              Your browser does not support video playback. <a href={DEMO_VIDEO.contentPath}>Open the video directly.</a>
            </video>
          </div>
          <div class="demo-caption"><strong>Recorded with Veqtor v0.1.2</strong><span>Claude explains and drafts · Veqtor reads, checks and writes · You review</span></div>
        </div>
        <div class="demo-hero__aside">
          <p>The demo uses synthetic documents and normal user prompts. No client data, hidden edits or pre-recorded product responses.</p>
          <span class="mono-note">1 minute 44 seconds · Veqtor v0.1.2 · Sample documents</span>
          <div class="actions"><a class="button button--primary" href="/setup">Connect Veqtor</a><a class="button button--secondary" href="#transcript">Read the transcript</a></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface demo-notes" aria-labelledby="video-heading">
    <div class="shell">
      <div class="section-heading">
        <div><p class="eyebrow">What you will see</p><h2 id="video-heading">A real Claude session with a disposable negotiation.</h2></div>
        <p>Claude compares the rounds, checks important wording and prepares a separate Word document. The original drafts stay unchanged.</p>
      </div>
      <p class="demo-install-note">This video was recorded with public v0.1.2: its “one command” line refers to Claude Code and its Desktop path used a configuration edit. The v0.3.0 release candidate adds a macOS Desktop extension, but that MCPB is not a public download until promotion succeeds. One correction: v0.1.2 checks the proposed Word document in memory before saving it; it does not reopen the saved copy for a separate final check.</p>
      <details class="demo-transcript" id="transcript">
        <summary>Read the corrected transcript</summary>
        <div>
          <p><strong>Correction:</strong> This transcript corrects two statements in the recorded narration about the final file check and setup.</p>
          <p>Claude can reason about a contract, but chat alone cannot reliably inspect several Word drafts or create precise tracked changes. An MCP server gives Claude specialized tools for that work. Claude still does the reasoning. The server performs the document work and returns results we can check against the source.</p>
          <p>Veqtor is an open-source MCP server for Word contract negotiations. It reads the redlines it supports, checks quotations against a specific tracked change, and creates new drafts with real tracked changes.</p>
          <p>In this demo, I ask what happened to the liability cap across four rounds. Veqtor extracts the tracked revisions. Claude turns the evidence into a clear explanation of how the cap and its carve-outs changed.</p>
          <p>Then I ask for the counterparty's exact latest wording. Instead of relying on the summary, Veqtor checks the quotation against that specific tracked change. In this run it matches exactly, and Veqtor returns the checked wording.</p>
          <p>Finally, I turn the review into an action: restore our 150% cap and the willful misconduct carve-out in a new round-five draft. The original stays untouched.</p>
          <p>Veqtor checks the complete set of requested edits, builds the proposed Word file in memory, and reads it again before saving anything. If the tracked changes it supports do not match the plan, it refuses to create the final file. Claude does the reasoning; Veqtor performs specific document steps that can be checked. Veqtor is free and open source. Public v0.1.2 uses one Claude Code registration command after uv is installed; the v0.3.0 candidate adds a macOS Claude Desktop extension that becomes public only after promotion.</p>
        </div>
      </details>
    </div>
  </section>

  <section class="section section--border" aria-labelledby="prompts-heading">
    <div class="shell">
      <div class="section-heading">
        <div><p class="eyebrow">The prompts</p><h2 id="prompts-heading">Ask in the language of the negotiation.</h2></div>
        <p>You do not need to know how Veqtor works inside. Describe the result you want, and Claude chooses the right step.</p>
      </div>
      <div class="prompt-grid">
        <article><span>01 / UNDERSTAND</span><blockquote>“What happened to the limitation of liability across the rounds?”</blockquote><p>Claude explains how the position changed from one draft to the next.</p></article>
        <article><span>02 / CHECK</span><blockquote>“Check the wording you quoted against the counterparty’s change.”</blockquote><p>Veqtor compares the quote with that specific tracked change.</p></article>
        <article><span>03 / RESPOND</span><blockquote>“Prepare our counterproposal in Word with tracked changes.”</blockquote><p>Veqtor tests the requested edits together and creates a separate file for review.</p></article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="try-heading">
    <div class="shell prose-shell">
      <article class="prose">
        <p class="eyebrow">Reproduce it</p>
        <h2 id="try-heading">Try the same workflow with fresh sample documents.</h2>
        <p>After connecting Veqtor, create a disposable four-round negotiation in your home folder:</p>
        <div class="code-block" data-copy-layer="technical"><div class="code-block__head"><span>Terminal</span><span>Public v0.1.2</span></div><pre><code>uvx --from "veqtor-mcp==0.1.2" veqtor-demo-rounds ~/veqtor-demo-rounds</code></pre></div>
        <p>Open a new Claude session and ask:</p>
        <blockquote>Using the Veqtor tools, what happened to the limitation of liability across the rounds in ~/veqtor-demo-rounds?</blockquote>
        <p>The sample is safe to discard and recreate. Use it to learn the workflow before pointing Claude at any real matter.</p>
        <div class="notice notice--lime"><strong>Use sample documents first</strong><p>Never include client text, private local paths or activity-history files in a public support request.</p></div>
      </article>
      <aside class="side-index" aria-label="Demo resources">
        <strong>Next</strong>
        <a href="/product">See what Veqtor can do</a>
        <a href="/setup">Connect Veqtor</a>
        <a href="/how-it-works">Understand the workflow</a>
        <a href="/limitations">Read the Alpha limits</a>
        <a href="https://github.com/JohnDeer-ai/veqtor-mcp">View source on GitHub</a>
      </aside>
    </div>
  </section>

  <SiteCta title="Ready to reproduce the demo on your computer?" primaryHref="/setup" primaryLabel="Open the connection guide" secondaryHref="/limitations" secondaryLabel="Read the limitations" />
</BaseLayout>

<style>
  .demo-hero { padding-bottom: clamp(42px, 6vw, 72px); padding-top: clamp(38px, 5vw, 62px); }
  .demo-hero__grid { align-items: start; display: grid; gap: 28px clamp(42px, 6vw, 78px); grid-template-areas: "title media" "aside media"; grid-template-columns: minmax(0, .82fr) minmax(440px, 1.18fr); margin-top: clamp(28px, 4vw, 48px); }
  .demo-hero__title { grid-area: title; }
  .demo-hero__title h1 { margin-bottom: 0; }
  .demo-hero__media { grid-area: media; min-width: 0; scroll-margin-top: 24px; }
  .demo-hero__aside { grid-area: aside; }
  .demo-hero__aside > p { color: var(--muted-strong); font-size: clamp(16px, 1.55vw, 19px); margin: 0; }
  .demo-hero__aside .mono-note { margin-top: 20px; }
  .demo-hero__aside .actions { margin-top: 24px; }
  .demo-video { background: #030205; border: 1px solid var(--line-strong); box-shadow: var(--shadow); }
  .demo-video video { aspect-ratio: 16/9; display: block; width: 100%; }
  .demo-caption { color: var(--muted); display: flex; flex-wrap: wrap; font-size: 12px; gap: 12px 24px; justify-content: space-between; padding-top: 14px; }
  .demo-caption strong { color: var(--ink); font-weight: var(--weight-title); }
  .demo-notes .section-heading { margin-bottom: clamp(24px, 3vw, 38px); }
  .demo-install-note { color: var(--muted); font-size: 13px; line-height: 1.55; margin: 0; }
  .demo-transcript { border-bottom: 1px solid var(--line); border-top: 1px solid var(--line); margin-top: 28px; }
  .demo-transcript summary { color: var(--muted-strong); cursor: pointer; font-size: 13px; padding: 18px 0; }
  .demo-transcript > div { color: var(--muted); font-size: 14px; line-height: 1.7; max-width: 840px; padding-bottom: 20px; }
  .demo-transcript p { margin: 0 0 16px; }
  .prompt-grid { border-top: 1px solid var(--line-strong); display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .prompt-grid article { padding: 28px clamp(18px, 3vw, 34px) 8px 0; }
  .prompt-grid article + article { border-left: 1px solid var(--line); padding-left: clamp(18px, 3vw, 34px); }
  .prompt-grid article > span { color: var(--violet); font-family: var(--mono); font-size: var(--type-micro); font-weight: var(--weight-label); }
  .prompt-grid blockquote { font-size: 19px; line-height: 1.45; margin: 34px 0 18px; }
  .prompt-grid p { color: var(--muted); font-size: 13px; }
  @media (max-width: 900px) { .demo-hero__grid { grid-template-areas: "title" "media" "aside"; grid-template-columns: minmax(0, 1fr); } .demo-hero__aside { max-width: 760px; } }
  @media (max-width: 760px) { .prompt-grid { grid-template-columns: 1fr; } .prompt-grid article { padding: 24px 0; } .prompt-grid article + article { border-left: 0; border-top: 1px solid var(--line); padding-left: 0; } }
</style>
