---
import BaseLayout from '../../layouts/BaseLayout.astro'
import {
  AUTHOR,
  MCP_GUIDE_BRIDGE,
  SITE_URL,
  TOPICS,
} from '../../lib/guides'

const about = AUTHOR.sections.find((section) => section.title === 'About')
const profileSections = AUTHOR.sections.filter((section) =>
  !['About', 'Writing by Ilya'].includes(section.title),
)
const aboutBody = [
  ...(about?.body.slice(0, 2) ?? []),
  'As founder of Veqtor, Ilya brings that contract-review experience to an open-source tool that helps Claude work with tracked changes in Word while keeping the original file untouched.',
]
const imagePath = AUTHOR.imageUrl.replace(SITE_URL, '')
const authorStructuredData = [
  {
    ...AUTHOR.schema,
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_URL}/` },
      { '@type': 'ListItem', position: 2, name: 'Ilya Shilov', item: `${SITE_URL}${AUTHOR.path}` },
    ],
  },
]
---

<BaseLayout
  title={AUTHOR.metaTitle}
  twitterTitle={AUTHOR.twitterTitle}
  description={AUTHOR.metaDescription}
  canonicalPath={AUTHOR.path}
  structuredData={authorStructuredData}
>
  <div class="author-page">
    <div class="shell crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span><b>Ilya Shilov</b>
    </div>

    <header class="author-hero shell">
      <div>
        <p class="kicker">{AUTHOR.eyebrow}</p>
        <h1>{AUTHOR.h1}</h1>
        <p class="lede">{AUTHOR.lede}</p>
        <div class="facts">
          {AUTHOR.facts.map((fact) => <span>{fact}</span>)}
        </div>
      </div>
      <figure>
        <img src={imagePath} width="800" height="1200" alt="Ilya Shilov" loading="eager" />
        <figcaption>
          {AUTHOR.sameAs[0] && <a href={AUTHOR.sameAs[0]} rel="me noreferrer">LinkedIn</a>}
          {AUTHOR.sameAs[1] && <a href={AUTHOR.sameAs[1]} rel="me noreferrer">Telegram</a>}
        </figcaption>
      </figure>
    </header>

    <section class="profile shell" aria-labelledby="about-heading">
      <article>
        <p class="kicker">Profile</p>
        <h2 id="about-heading">About</h2>
        {aboutBody.map((paragraph) => <p>{paragraph}</p>)}
        {profileSections.map((section) => (
          <section>
            <h3>{section.title}</h3>
            {section.body.map((paragraph) => <p>{paragraph}</p>)}
          </section>
        ))}
      </article>
      <aside>
        <p class="kicker">Core expertise</p>
        <div class="expertise">
          {AUTHOR.expertise.map((item) => <span>{item}</span>)}
        </div>
      </aside>
    </section>

    <section class="writing" aria-labelledby="writing-heading">
      <div class="shell">
        <div class="section-heading">
          <div>
            <p class="kicker">Writing by Ilya</p>
            <h2 id="writing-heading">Practical English-law contract guides.</h2>
          </div>
          <p>Every published guide remains connected to its main topic and the rest of the library.</p>
        </div>
        <div class="topic-writing">
          {TOPICS.map((topic) => (
            <section>
              <header>
                <div>
                  <span>{topic.stage.label}</span>
                  <h3><a href={topic.path}>{topic.label}</a></h3>
                </div>
                <b>{topic.guides.length}</b>
              </header>
              <nav aria-label={`${topic.label} guides by Ilya Shilov`}>
                {topic.guides.map((guide) => (
                  <a href={guide.path}>
                    <span>{guide.kind === 'pillar' ? 'Pillar' : guide.listing.label}</span>
                    <strong>{guide.listing.title}</strong>
                  </a>
                ))}
              </nav>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section class="bridge shell" aria-labelledby="author-bridge-heading">
      <div>
        <p class="kicker">{MCP_GUIDE_BRIDGE.label}</p>
        <h2 id="author-bridge-heading">From legal context to the actual negotiation drafts.</h2>
        <p>{MCP_GUIDE_BRIDGE.body}</p>
      </div>
      <a href={MCP_GUIDE_BRIDGE.href}>{MCP_GUIDE_BRIDGE.title}</a>
    </section>
  </div>
</BaseLayout>

<style>
  .author-page {
    --ink: #eeedf5;
    --muted: #aaa6b7;
    --panel: #111019;
    --panel-raised: #17151f;
    --line: #302d3c;
    --accent: #8f80ff;
    --accent-soft: #c0b9ff;
    color: var(--ink);
  }

  .shell {
    width: min(1160px, calc(100% - 2.5rem));
    margin-inline: auto;
  }

  .crumbs {
    display: flex;
    gap: 0.5rem;
    padding-top: 1.4rem;
    color: var(--muted);
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.72rem;
  }

  .crumbs a {
    color: inherit;
    text-decoration: none;
  }

  .crumbs b {
    color: var(--ink);
  }

  .author-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(16rem, 0.45fr);
    gap: clamp(2.5rem, 9vw, 9rem);
    align-items: end;
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .kicker,
  .topic-writing header span {
    margin: 0 0 1rem;
    color: var(--accent-soft);
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.72rem;
    font-weight: var(--weight-label);
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 13ch;
    margin-bottom: 1.4rem;
    font-size: var(--type-page-title);
    letter-spacing: var(--tracking-display);
    line-height: 1.04;
    text-wrap: balance;
  }

  .lede {
    max-width: 52ch;
    color: var(--muted);
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    line-height: 1.65;
  }

  .facts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.6rem;
  }

  .facts span,
  .expertise span {
    padding: 0.45rem 0.65rem;
    color: var(--muted);
    font-size: 0.76rem;
    border: 1px solid var(--line);
    border-radius: 999px;
  }

  figure {
    margin: 0;
    padding: 0.7rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 1rem;
  }

  figure img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border-radius: 0.65rem;
    filter: saturate(0.7) contrast(1.04);
  }

  figcaption {
    display: flex;
    gap: 0.6rem;
    padding: 0.75rem 0.2rem 0.1rem;
  }

  figcaption a {
    color: var(--accent-soft);
    font-size: 0.76rem;
    text-decoration: none;
  }

  .profile {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(13rem, 0.36fr);
    gap: clamp(3rem, 8vw, 8rem);
    padding-block: clamp(3rem, 7vw, 6rem);
    border-top: 1px solid var(--line);
  }

  .profile article > h2,
  .section-heading h2,
  .bridge h2 {
    margin-bottom: 1.25rem;
    font-size: var(--type-section-title);
    letter-spacing: var(--tracking-heading);
    line-height: 1.08;
  }

  .profile article > p,
  .profile article section p,
  .section-heading > p,
  .bridge p {
    color: #c4c1cd;
    font-size: 1.02rem;
    line-height: 1.78;
  }

  .profile article section {
    padding-top: 1.5rem;
    margin-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .profile article section h3 {
    margin-bottom: 0.65rem;
    font-size: 1.12rem;
  }

  .profile aside {
    position: sticky;
    top: 6rem;
    align-self: start;
    padding: 1.25rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 0.85rem;
  }

  .expertise {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .writing {
    padding-block: clamp(4rem, 8vw, 7rem);
    background: #0d0c13;
    border-block: 1px solid var(--line);
  }

  .section-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(16rem, 0.43fr);
    gap: 2rem;
    align-items: end;
    margin-bottom: 2rem;
  }

  .section-heading h2 {
    max-width: 18ch;
    margin-bottom: 0;
  }

  .section-heading > p {
    margin-bottom: 0;
    color: var(--muted);
  }

  .topic-writing {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .topic-writing > section {
    padding: 1.25rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 0.85rem;
  }

  .topic-writing header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }

  .topic-writing header span {
    display: block;
    margin-bottom: 0.35rem;
  }

  .topic-writing h3 {
    margin-bottom: 0;
    font-size: 1.18rem;
  }

  .topic-writing h3 a {
    color: var(--ink);
    text-decoration: none;
  }

  .topic-writing header b {
    color: var(--accent-soft);
    font-size: 2rem;
    font-weight: var(--weight-display);
    letter-spacing: -0.03em;
  }

  .topic-writing nav {
    display: flex;
    flex-direction: column;
  }

  .topic-writing nav a {
    display: grid;
    grid-template-columns: minmax(5rem, 0.25fr) 1fr;
    gap: 0.6rem;
    padding-block: 0.65rem;
    color: var(--ink);
    font-size: 0.78rem;
    line-height: 1.35;
    text-decoration: none;
    border-bottom: 1px solid var(--line);
  }

  .topic-writing nav a span {
    color: var(--accent-soft);
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .bridge {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: end;
    margin-block: clamp(4rem, 9vw, 8rem);
    padding: clamp(1.6rem, 4vw, 3rem);
    background: linear-gradient(120deg, rgb(143 128 255 / 17%), transparent 62%), var(--panel-raised);
    border: 1px solid var(--line);
    border-radius: 1rem;
  }

  .bridge h2 {
    max-width: 18ch;
  }

  .bridge p {
    max-width: 65ch;
    margin-bottom: 0;
    color: var(--muted);
  }

  .bridge > a {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 1.05rem;
    color: #0b0912;
    font-size: 0.82rem;
    font-weight: var(--weight-control);
    text-decoration: none;
    background: var(--accent-soft);
    border-radius: 0.55rem;
  }

  @media (max-width: 1080px) {
    .author-hero,
    .profile,
    .section-heading,
    .bridge {
      grid-template-columns: 1fr;
    }

    figure {
      max-width: 20rem;
    }

    .profile aside {
      position: static;
    }

    .bridge > a {
      justify-self: start;
    }
  }

  @media (max-width: 620px) {
    .topic-writing {
      grid-template-columns: 1fr;
    }

    .shell {
      width: min(100% - 1.25rem, 1160px);
    }
  }
</style>
