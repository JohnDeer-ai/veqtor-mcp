/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; connect-src 'self'; font-src 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data:; media-src 'self'; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; upgrade-insecure-requests

/assets/*
  Cache-Control: public, max-age=86400, must-revalidate

/og.png
  Cache-Control: public, max-age=86400, must-revalidate

/logo-512.png
  Cache-Control: public, max-age=86400, must-revalidate

/favicon*
  Cache-Control: public, max-age=86400, must-revalidate

/apple-touch-icon.png
  Cache-Control: public, max-age=86400, must-revalidate

/site.webmanifest
  Cache-Control: public, max-age=86400, must-revalidate

/web-app-manifest-*
  Cache-Control: public, max-age=86400, must-revalidate

/media/veqtor-demo-v0.1.2.mp4
  Cache-Control: public, max-age=31536000, immutable

/media/veqtor-demo-v0.1.2-poster.jpg
  Cache-Control: public, max-age=31536000, immutable

/media/veqtor-demo-v0.1.2-r2.en.vtt
  Cache-Control: public, max-age=31536000, immutable

/sitemap.xml
  Cache-Control: public, max-age=3600
